# API keys for external providers (optional — local ollama works without any)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Agent configuration
TINYAGENT_BUDGET=5.0
TINYAGENT_OLLAMA_MODEL=llama3.2
TINYAGENT_VERBOSE=false

# Ollama host (optional, defaults to http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434
